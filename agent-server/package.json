{
  "name": "agent-server",
  "version": "1.0.0",
  "description": "Express + Mongoose backend that hosts the Claude Agent SDK and streams events over SSE",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "cli": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.server.json",
    "build:all": "tsc",
    "start": "node dist/src/server.js",
    "start:cli": "node dist/src/main.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "mongoose": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.1",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3"
  }
}
