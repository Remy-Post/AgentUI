{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(AGENT_SERVER_PORT=3001 timeout 8 npx tsx agent-server/src/server.ts)",
      "Bash(AGENT_SERVER_PORT=3002 npx tsx *)",
      "Bash(curl -s http://127.0.0.1:3002/health)",
      "Bash(curl -s http://127.0.0.1:3002/api/settings)",
      "Bash(curl -s http://127.0.0.1:3002/api/tools)",
      "Bash(curl -s -X PUT http://127.0.0.1:3002/api/settings -H \"Content-Type: application/json\" -d '{\"defaultModel\":\"claude-opus-4\"}')",
      "Bash(curl -s -X PATCH http://127.0.0.1:3002/api/tools/grep -H \"Content-Type: application/json\" -d '{\"enabled\":false}')",
      "Bash(curl -s -X PATCH http://127.0.0.1:3002/api/sessions/000000000000000000000000 -H \"Content-Type: application/json\" -d '{\"effort\":\"high\"}')",
      "Bash(curl -s -X PATCH http://127.0.0.1:3002/api/sessions/notvalid -H \"Content-Type: application/json\" -d '{\"effort\":\"high\"}')",
      "Bash(curl -s -X PATCH http://127.0.0.1:3002/api/skills/notvalid -H \"Content-Type: application/json\" -d '{\"description\":\"x\"}')",
      "Bash(curl -s -X PATCH http://127.0.0.1:3002/api/subagents/notvalid -H \"Content-Type: application/json\" -d '{\"description\":\"x\"}')"
    ]
  }
}
